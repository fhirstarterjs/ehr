{
   "compilerOptions": {
      "target": "ESNext",
      "module": "ESNext",
      "moduleResolution": "bundler",
      "lib": ["ESNext", "DOM", "DOM.Iterable"],
      "jsx": "react-jsx",
      "strict": true,
      "noUncheckedIndexedAccess": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "declaration": true,
      "emitDeclarationOnly": true,
      "outDir": "dist",
      "verbatimModuleSyntax": true,
      "noEmitOnError": true
   },
   "include": ["ts", "ui", "types", "ui/**/*.vue"]
}
